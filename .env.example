# Bayanihan Connect — Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ─── Database Configuration ───────────────────────────────────
DB_HOST=your-database-host.com
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=bayanihan_connect

# ─── Server Configuration ─────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Frontend Configuration ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── File Upload Settings ─────────────────────────────────────
# For local development, uploads go to /backend/uploads
# For production, consider using cloud storage like AWS S3 or Vercel Blob
MAX_UPLOAD_SIZE=5242880

# ─── Database Notes ───────────────────────────────────────────
# For Vercel deployment, use one of these options:
#
# PlanetScale (Recommended):
#   1. Create account at https://planetscale.com
#   2. Create database 'bayanihan_connect'
#   3. Get connection string from Branches → main → Connect
#   Example: mysql://user:password@host/bayanihan_connect?sslaccept=strict
#
# AWS RDS MySQL:
#   1. Create RDS instance
#   2. Allow Vercel IPs in security group
#   3. Import schema from database/schema.sql
#
# Supabase MySQL:
#   1. Create project with MySQL
#   2. Get connection details from Settings → Database

# ─── Vercel Deployment ────────────────────────────────────────
# When deploying to Vercel:
# 1. Add these variables in Vercel project settings
# 2. Set FRONTEND_URL to your Vercel frontend domain
# 3. Vercel will set PORT automatically
# 4. Use connection pooling for serverless (PlanetScale recommended)
